  <div class="card map-card">
    <div class="map-card__body">
      <div class="trend-head">
        <div class="trend-head__top">
          <div class="trend-head__heading">
            <span class="data-grid-card__title" id="national-trend-title">
              Enrollment Trends
            </span>
            <p class="data-grid-card__instruction" id="national-trend-sub">National · Hospital / Medical</p>
          </div>
          <button
            type="button"
            class="data-grid-card__expand"
            id="trend-expand-trigger"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="trend-overlay"
            aria-label="Expand Enrollment Trends"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
              <path d="M6 2H2v4M10 2h4v4M2 10v4h4M14 10v4h-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
        <div class="trend-head__controls">
          <div class="tabs" id="national-range-tabs" role="tablist" aria-label="Time range">
            <button type="button" role="tab" class="chart-range-tab" aria-selected="true" data-range="yearly">Yearly</button>
            <button type="button" role="tab" class="chart-range-tab" aria-selected="false" data-range="monthly">Monthly</button>
          </div>
        </div>
      </div>

      <div id="chartsView">
        <div class="chart-block trend-panel" data-view="line" id="trend-panel-line">
          <div class="chart-block__head"><h4>Enrollment Count</h4><div class="legend" id="national-trend-line-legend"></div></div>
          <div class="table-container" id="national-trend-line"></div>
        </div>

        {# Mobile-only carousel panel 2 — real bar chart, same #national-trend-bar
           id renderTrend() already targets, so it's scope-aware (national/state/
           county) the same way the line panel above is. #}
        <div class="chart-block trend-panel trend-panel--mobile-only" data-view="bar" id="trend-panel-bar">
          <div class="chart-block__head"><h4>Percent of Total Enrollment</h4><div class="legend" id="national-trend-bar-legend"></div></div>
          <div class="table-container" id="national-trend-bar"></div>
        </div>

        {# Mobile-only carousel panel 3 — tap to open #trend-drawer, showing
           the full yearly/monthly trend data table. #}
        <div class="chart-block trend-panel trend-panel--mobile-only" data-view="grid" id="trend-panel-grid">
          <div class="data-grid-card__mobile-trigger-wrap">
            <button
              type="button"
              class="data-grid-card__mobile-trigger"
              id="trend-mobile-trigger"
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="trend-drawer"
            >
              <span class="data-grid-card__mobile-trigger-top">
                <span class="data-grid-card__mobile-trigger-heading">
                  <span class="data-grid-card__mobile-trigger-title">Trend Data Table</span>
                </span>
                <svg class="data-grid-card__mobile-trigger-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" focusable="false">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="data-grid-card__mobile-trigger-desc" id="trend-mobile-trigger-desc">Open to view the full yearly trend data table.</span>
            </button>
          </div>
          <hr class="data-grid-card__mobile-divider" aria-hidden="true">
        </div>
      </div>

      <div class="trend-carousel-dots" id="trend-carousel-dots">
        <button type="button" class="trend-carousel-dot" data-view="line" aria-pressed="true" aria-controls="trend-panel-line" aria-label="Show enrollment line chart"></button>
        <button type="button" class="trend-carousel-dot" data-view="bar" aria-pressed="false" aria-controls="trend-panel-bar" aria-label="Show percent of total enrollment chart"></button>
        <button type="button" class="trend-carousel-dot" data-view="grid" aria-pressed="false" aria-controls="trend-panel-grid" aria-label="Show grid placeholder"></button>
      </div>
    </div>
  </div>

  <!--
    Desktop "expand" overlay for the trend card. Unlike the enrollment
    overlay, this has no live content to reparent — the body is static
    placeholder markup baked in from the start. Real chart/bar/grid content
    will replace this WIP text in a later pass. See allAreas.js's
    openTrendOverlay/closeTrendOverlay.
  -->
  <div class="data-grid-overlay-scrim" id="trend-overlay-scrim"></div>
  <div
    class="data-grid-overlay"
    id="trend-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="trend-overlay-title"
  >
    <header class="data-grid-overlay__header">
      <div class="data-grid-overlay__header-row">
        <div>
          <h3 class="data-grid-overlay__title" id="trend-overlay-title">Enrollment Trends</h3>
          <p class="data-grid-overlay__sub" id="trend-overlay-sub">National · Hospital / Medical</p>
        </div>
        <button type="button" class="data-grid-overlay__close" id="trend-overlay-close" aria-label="Minimize Enrollment Trends">
          <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          </svg>
        </button>
      </div>
      <div class="data-grid-overlay__tabs-slot trend-overlay__toolbar">
        <div class="tabs" id="trend-overlay-range" role="tablist" aria-label="Time range">
          <button type="button" role="tab" class="chart-range-tab" data-range="yearly" aria-selected="true">Yearly</button>
          <button type="button" role="tab" class="chart-range-tab" data-range="monthly" aria-selected="false">Monthly</button>
        </div>
        <div class="segmented trend-overlay__types" id="trend-overlay-types" role="group" aria-label="Chart type">
          <button type="button" data-view="line" aria-pressed="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 17l5-6 4 3 6-8" /></svg>Line
          </button>
          <button type="button" data-view="bar" aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 21V10M12 21V4M19 21v-7" /></svg>Bar
          </button>
          <button type="button" data-view="grid" aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="1.5" /><path d="M3 10h18M3 15h18M9 4v16" /></svg>Grid
          </button>
        </div>
      </div>
    </header>
    <div class="data-grid-overlay__body" id="trend-overlay-body">
      <div class="chart-block trend-overlay__panel" id="trend-overlay-line-panel">
        <div class="chart-block__head"><h4>Enrollment Count</h4><div class="legend" id="trend-overlay-line-legend"></div></div>
        <div class="table-container" id="trend-overlay-line"></div>
      </div>
      <div class="chart-block trend-overlay__panel" id="trend-overlay-bar-panel" hidden>
        <div class="chart-block__head"><h4>Percent of Total Enrollment</h4><div class="legend" id="trend-overlay-bar-legend"></div></div>
        <div class="table-container" id="trend-overlay-bar"></div>
      </div>
      <div class="trend-overlay__panel trend-overlay__panel--grid" id="trend-overlay-grid-panel" hidden>
        <div class="data-grid-scroll-wrap"><div class="data-grid-scroll" id="trend-overlay-grid"></div></div>
      </div>
    </div>
  </div>

  <!--
    Mobile-only bottom-sheet drawer for the trend data table, opened from
    #trend-panel-grid (carousel page 3). Simpler than the state/county
    drawers -- no search box, just the current yearly/monthly table.
  -->
  <div class="data-grid-drawer-overlay" id="trend-drawer-overlay"></div>
  <div
    class="data-grid-drawer"
    id="trend-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="trend-drawer-title"
  >
    <div class="data-grid-drawer__handle" aria-hidden="true"></div>
    <header class="data-grid-drawer__header">
      <h3 class="data-grid-drawer__title" id="trend-drawer-title">Trend Data Table</h3>
      <button type="button" class="data-grid-drawer__close" id="trend-drawer-close" aria-label="Close trend data table">
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
          <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        </svg>
      </button>
    </header>
    <div class="data-grid-drawer__list-wrap" id="trend-drawer-body"></div>
  </div>
