<div class="page-header">
  <h1 class="page-header__title">Medicare Enrollment Dashboard</h1>

  <div class="page-header__meta">
    <div class="topbar">
      <span class="hint">Click to swap dashboards:</span>
      <div class="segmented" role="group" aria-label="Choose enrollment dashboard type">
        <button type="button" class="dashboard-type-button" data-dashboard-type="hospital" aria-pressed="true">
          {% usa_icons 'location_city' %}
          Hospital / Medical
        </button>
        <button type="button" class="dashboard-type-button" data-dashboard-type="drug" aria-pressed="false">
          {% usa_icons 'local_pharmacy' %}
          Prescription Drug
        </button>
      </div>
    </div>

    <p class="page-header__updated lab">Last updated: <span id="dashboard-title-date"></span></p>
  </div>
</div>
