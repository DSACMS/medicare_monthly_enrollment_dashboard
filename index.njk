    .tt .tt-h { font-weight: 700; margin-bottom: 6px; }
    .tt .tt-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
    .tt .tt-row .lab { display: flex; align-items: center; gap: 7px; color: var(--ink-2); }
    .tt .tt-row .val { font-weight: 700; font-variant-numeric: tabular-nums; }
    .tt .k { width: 9px; height: 9px; border-radius: 2px; flex: none; }

    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
    .footnote { font-size: .73rem; color: var(--ink-2); margin-top: 12px; }

    @media (max-width: 960px) {
