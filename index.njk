    .segmented button[aria-pressed="true"] { background: var(--surface); color: var(--brand-ink); box-shadow: 0 1px 2px rgba(16,16,24,.12); border: 1px solid var(--border); }
    .segmented button svg { width: 16px; height: 16px; }
    .hint { font-size: .8rem; color: var(--ink-2); font-weight: 600; }

    .topbar { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; margin-bottom: 12px; }
    .topbar .push { margin-left: auto; }
    .topbar .rule { width: 1px; align-self: stretch; background: var(--border); margin: 2px 2px; }

    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 15px; box-shadow: var(--shadow); }
    .card__title { font-size: .95rem; font-weight: 700; margin: 0; }
    .card__sub   { font-size: .75rem; color: var(--ink-2); margin: 2px 0 0; }

    .dash-grid { display: grid; grid-template-columns: minmax(0, 1.16fr) minmax(0, 0.84fr); gap: 14px; align-items: stretch; }
    .col { display: grid; gap: 14px; align-content: stretch; }

    .dash-grid.is-grid { grid-template-columns: 1fr; }
    .tables-flex { display: grid; gap: 14px; }
    .tables-flex > .chart-block { min-width: 0; margin-top: 0; }

    .swatch { width: 11px; height: 11px; border-radius: 3px; flex: none; }
    .dash-hero { padding: 14px 18px; margin-bottom: 14px; display: flex; align-items: center; gap: clamp(18px, 3vw, 36px); }
    .dash-hero__total { flex: none; }
    .dash-hero__total .lab { display: block; font-size: .7rem; font-weight: 700; color: var(--ink-2); text-transform: uppercase; letter-spacing: .05em; }

    .dash-hero__total b { display: block; font-size: 3rem; font-weight: 800; letter-spacing: -.03em; line-height: 1.06; }

    .dash-hero__split { flex: 1; min-width: 0; display: grid;
      grid-template-columns: max-content minmax(0, 1fr) max-content;
      gap: 9px 12px; align-items: center; }
    .dash-hero__split .key { display: inline-flex; align-items: center; gap: 7px; font-size: .78rem; color: var(--ink-2); font-weight: 600; white-space: nowrap; }

    .dash-hero__bar { display: block; height: 13px; border-radius: 0 4px 4px 0; min-width: 3px; }
    .dash-hero__val { display: inline-flex; align-items: baseline; gap: 8px; font-size: .78rem; color: var(--ink-2); font-weight: 600; white-space: nowrap; }
    .dash-hero__val b { color: var(--ink); font-weight: 700; font-size: .86rem; }

    .map-card { padding: 14px 16px; display: flex; flex-direction: column; }
    .map-head { margin-bottom: 6px; }

    #mapView { flex: 1; display: flex; flex-direction: column; }
    .map-figure { position: relative; flex: 1; display: flex; align-items: center; }
    .map-figure svg { width: 100%; height: auto; display: block; }
    .map-figure .state { stroke: var(--surface); stroke-width: .7px; cursor: pointer; transition: opacity .12s; }
    .map-figure .state:hover { opacity: .82; }
    .map-figure .state.is-selected { stroke: var(--ink); stroke-width: 2px; }
    .map-loading, .map-error { padding: 42px 20px; text-align: center; color: var(--ink-2); font-size: .9rem; }
    .legend-scale { display: flex; flex-wrap: wrap; gap: 4px 12px; margin-top: 10px; }
    .legend-scale .item { display: flex; align-items: center; gap: 6px; font-size: .72rem; color: var(--ink-2); }
    .legend-scale .chip { width: 13px; height: 13px; border-radius: 3px; }
    .focus-line { margin-top: 10px; font-size: .8rem; color: var(--ink-2); border-top: 1px dashed var(--border); padding-top: 9px; }
    .focus-line b { color: var(--ink); }
    .focus-line .sep { opacity: .5; margin: 0 6px; }

    .table-title { font-size: .82rem; font-weight: 700; margin: 2px 0 6px; }
    .table-scroll { overflow: auto; max-height: 320px; border: 1px solid var(--border); border-radius: 10px; }
