<div class="dashboard-root">
  {% include "title-bar.njk" %}
  {% include "hero-card.njk" %}

  <div class="US_MAPS dashboard-map-panel" data-map-dashboard-type="hospital" aria-hidden="false">
    <ul class="usa-card-group">
      <li class="usa-card">
        <div class="usa-card__container">
          <div class="usa-card__body grid-row">

            <!-- LEFT: 4/12 columns -->
            <div class="grid-col-4 display-flex flex-column height-full padding-3 border-right border-base-lighter">
              <div class="display-flex flex-column">

                <div class="margin-bottom-3">
                  <h3 class="margin-0 margin-bottom-105 text-uppercase text-base font-body-3xs">Penetration Rate</h3>
                  <ul class="usa-list usa-list--unstyled">
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-1 margin-right-105 height-105 width-105 radius-sm"></span> 1% - 17%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-2 margin-right-105 height-105 width-105 radius-sm"></span> 17% - 34%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-3 margin-right-105 height-105 width-105 radius-sm"></span> 34% - 51%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-4 margin-right-105 height-105 width-105 radius-sm"></span> 51% - 67%
                    </li>
                    <li class="display-flex flex-align-center">
                      <span class="bg-custom-5 margin-right-105 height-105 width-105 radius-sm"></span> 67% - 87%
                    </li>
                  </ul>
                </div>

                <div class="usa-summary-box" role="region" aria-labelledby="map-summary-heading">
                  <div class="usa-summary-box__body">
                    <div class="usa-summary-box__text">
                      *Map includes data for all 50 United States plus Washington D.C. <br><br>
                      Click to View State level information.<br><br>
                      See "Grid" for additional US territories.
                    </div>
                  </div>
                </div>

              </div>
            </div>

            <!-- RIGHT: 8/12 columns — now holds the state selector + map -->
            <div class="grid-col-8 display-flex flex-column height-full padding-3">
              <div class="state-map-selection">

                <label class="usa-label" for="medicare-state-selector">Select a state to view <strong>county heat
                    map:</strong></label>
                <div class="usa-combo-box">
                  <select class="usa-select" name="medicare-state" id="medicare-state-selector">
                    <option value="">Select a state</option>
                    {% for state in usStates %}
                    <option value="{{ state }}">{{ state }}</option>
                    {% endfor %}
                  </select>
                </div>

                <div class="table-container flex-1 width-full margin-top-2" id="medicare-enrollment-state-map"></div>
              </div>
            </div>

          </div>
        </div>
      </li>
    </ul>
  </div>

  <div class="US_MAPS dashboard-map-panel" data-map-dashboard-type="drug" hidden aria-hidden="true">
    <ul class="usa-card-group">
      <li class="usa-card">
        <div class="usa-card__container">
          <div class="usa-card__body grid-row">

            <!-- LEFT: 4/12 columns -->
            <div class="grid-col-4 display-flex flex-column height-full padding-3 border-right border-base-lighter">
              <div class="display-flex flex-column">

                <div class="margin-bottom-3">
                  <h3 class="margin-0 margin-bottom-105 text-uppercase text-base font-body-3xs">Penetration Rate</h3>
                  <ul class="usa-list usa-list--unstyled">
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-6 margin-right-105 height-105 width-105 radius-sm"></span> 1% - 17%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-7 margin-right-105 height-105 width-105 radius-sm"></span> 17% - 34%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-8 margin-right-105 height-105 width-105 radius-sm"></span> 34% - 51%
                    </li>
                    <li class="display-flex flex-align-center margin-bottom-105">
                      <span class="bg-custom-9 margin-right-105 height-105 width-105 radius-sm"></span> 51% - 67%
                    </li>
                    <li class="display-flex flex-align-center">
                      <span class="bg-custom-10 margin-right-105 height-105 width-105 radius-sm"></span> 67% - 87%
                    </li>
                  </ul>
                </div>

                <div class="usa-summary-box" role="region" aria-labelledby="map-summary-heading">
                  <div class="usa-summary-box__body">
                    <div class="usa-summary-box__text">
                      *Map includes data for all 50 United States plus Washington D.C. <br><br>
                      Click to View State level information.<br><br>
                      See "Grid" for additional US territories.
                    </div>
                  </div>
                </div>

              </div>
            </div>

            <!-- RIGHT: 8/12 columns — now holds the state selector + map -->
            <div class="grid-col-8 display-flex flex-column height-full padding-3">
              <div class="state-map-selection">

                <label class="usa-label" for="drug-state-selector">Select a state to view <strong>county heat
                    map:</strong></label>
                <div class="usa-combo-box">
                  <select class="usa-select" name="drug-state" id="drug-state-selector">
                    <option value="">Select a state</option>
                    {% for state in usStates %}
                    <option value="{{ state }}">{{ state }}</option>
                    {% endfor %}
                  </select>
                </div>

                <div class="table-container flex-1 width-full margin-top-2" id="medicare-mapd-state-map"></div>
              </div>
            </div>

          </div>
        </div>
      </li>
    </ul>
  </div>

  {% include "data-grid-cards.njk" %}
</div>



<!-- 1. Keep the template header section -->
<div class="usa-section intro-header">
  <div class="grid-container">
    <h1 class="visually-hidden">{{ title }}</h1>
    <p class="usa-intro usa-intro--sections no-print">{{ description }}</p>
  </div>
</div>

<!-- 2. Your Dashboard Sections go inside the main container layout -->
<div class="usa-section layout--sections">
  <div class="grid-container"> 
    <!-- Added to match USWDS layout system padding -->

    <!-- National Enrollment Trends -->
    <section id="national">
      <h2>Medicare National Enrollment Trends (2018 - 2026)</h2>

      <h3>Hospital / Medical — Yearly Trend</h3>
      <h4>Enrollment Count</h4>
      <div class="table-container" id="national-hospital-yearly-line"></div>
      <h4>Percent of Total Enrollment</h4>
      <div class="table-container" id="national-hospital-yearly-bar"></div>

      <h3>Hospital / Medical — 12-Month Trend</h3>
      <h4>Enrollment Count</h4>
      <div class="table-container" id="national-hospital-monthly-line"></div>
      <h4>Percent of Total Enrollment</h4>
      <div class="table-container" id="national-hospital-monthly-bar"></div>

      <h3>Prescription Drug — Yearly Trend</h3>
      <h4>Enrollment Count</h4>
      <div class="table-container" id="national-drug-yearly-line"></div>
      <h4>Percent of Total Enrollment</h4>
      <div class="table-container" id="national-drug-yearly-bar"></div>

      <h3>Prescription Drug — 12-Month Trend</h3>
      <h4>Enrollment Count</h4>
      <div class="table-container" id="national-drug-monthly-line"></div>
      <h4>Percent of Total Enrollment</h4>
      <div class="table-container" id="national-drug-monthly-bar"></div>

      <h3>Data Table</h3>
      <div class="table-container" id="medicare-table"></div>

      <h3>Enrollment Breakdown — Current Year</h3>
      <div class="table-container" id="drug-enrollment-pie"></div>


  </section>

  <!-- State Enrollment -->
  <section id="state">
    <h2>State Enrollment — Hospital / Medical</h2>
    <h3>Yearly Trend</h3>
    <h4>Enrollment Count</h4>
    <div class="table-container" id="state-hospital-yearly-line"></div>
    <h4>Percent of Total Enrollment</h4>
    <div class="table-container" id="state-hospital-yearly-bar"></div>
    <h4>Data Table</h4>
    <div class="table-container" id="state-hospital-yearly"></div>

    <h3>12-Month Trend</h3>
    <h4>Enrollment Count</h4>
    <div class="table-container" id="state-hospital-monthly-line"></div>
    <h4>Percent of Total Enrollment</h4>
    <div class="table-container" id="state-hospital-monthly-bar"></div>
    <h4>Data Table</h4>
    <div class="table-container" id="state-hospital-monthly"></div>

    <h2>State Enrollment — Prescription Drug</h2>
    <h3>Yearly Trend</h3>
    <h4>Enrollment Count</h4>
    <div class="table-container" id="state-drug-yearly-line"></div>
    <h4>Percent of Total Enrollment</h4>
    <div class="table-container" id="state-drug-yearly-bar"></div>
    <h4>Data Table</h4>
    <div class="table-container" id="state-drug-yearly"></div>

    <h3>12-Month Trend</h3>
    <h4>Enrollment Count</h4>
    <div class="table-container" id="state-drug-monthly-line"></div>
    <h4>Percent of Total Enrollment</h4>
    <div class="table-container" id="state-drug-monthly-bar"></div>
    <h4>Data Table</h4>
    <div class="table-container" id="state-drug-monthly"></div>
  </section>

</div>
</div>