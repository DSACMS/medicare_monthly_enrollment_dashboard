  'Rhode Island':'RI','South Carolina':'SC','South Dakota':'SD','Tennessee':'TN','Texas':'TX','Utah':'UT',
  'Vermont':'VT','Virginia':'VA','Washington':'WA','West Virginia':'WV','Wisconsin':'WI','Wyoming':'WY',
  'American Samoa':'AS','Guam':'GU','Northern Mariana Islands':'MP','Puerto Rico':'PR','U.S. Virgin Islands':'VI',
  'Foreign and Other Outlying Areas':'Other'
};

function seed(str) { let h = 2166136261; for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h = Math.imul(h, 16777619); } return h >>> 0; }
function toCount(vM, key) { const base = vM * 1e6; const frac = (seed(key) % 100000) / 100000 - 0.5; return Math.max(0, Math.round(base + frac * Math.max(base * 0.012, 18000))); }

function areaRow(name, arr) {
  let ma = arr[0]; if (dash === 'drug') ma = Math.min(85, Math.round(ma * 1.12));
  const total = toCount(arr[1], name + dash);
  const a = Math.round(total * ma / 100), b = total - a;
  return { name, total, a, b, aPct: ma, bPct: 100 - ma };
}

function natRow(d, key) {
  const a = toCount(d.a, key + 'a' + dash), b = toCount(d.b, key + 'b' + dash), total = a + b;
  const aPct = Math.round(a / total * 100);
  return { total, a, b, aPct, bPct: 100 - aPct };
}

let dash = 'hospital', range = 'yearly', view = 'map', selectedState = '';

function renderHero() {
  const s = DATA[dash].snapshot, L = DATA[dash].labels;
  document.getElementById('maName').textContent = L.a;
  document.getElementById('ffsName').textContent = L.b;
  document.getElementById('maBig').textContent = fmtM(s.a);
  document.getElementById('ffsBig').textContent = fmtM(s.b);
  document.getElementById('maSub').textContent = pct(s.a, s.total) + '%';
  document.getElementById('ffsSub').textContent = pct(s.b, s.total) + '%';
  document.getElementById('heroTotal').textContent = fmtM(s.total);

  document.getElementById('segA').style.width = (s.a / s.total * 100) + '%';
  document.getElementById('segB').style.width = (s.b / s.total * 100) + '%';
  document.getElementById('splitBar').setAttribute('aria-label',
    `${L.a} ${pct(s.a,s.total)} percent, ${L.b} ${pct(s.b,s.total)} percent of ${fmtM(s.total)} total`);
}

function buildLegend(el, items) {
  el.innerHTML = items.map(it => `<span class="item"><span class="key ${it.dot?'dot':''}" style="background:${it.c}"></span>${it.label}</span>`).join('');
}

function renderLine() {
  const rows = DATA[dash][range], L = DATA[dash].labels;
  const svg = d3.select('#lineChart'); svg.selectAll('*').remove();
  const W = 560, H = 270, m = { t: 12, r: 58, b: 30, l: 44 };
  const series = [
    { label: 'Total', color: css('--total'), get: d => d.a + d.b, labelIt: true },
    { label: L.aShort, color: css('--ma'),  get: d => d.a, labelIt: false },
    { label: L.bShort, color: css('--ffs'), get: d => d.b, labelIt: false },
  ];
  const maxV = d3.max(rows, d => d.a + d.b) * 1.08;
  const x = d3.scalePoint().domain(rows.map(d => d.t)).range([m.l, W - m.r]).padding(0.5);
  const y = d3.scaleLinear().domain([0, maxV]).nice().range([H - m.b, m.t]);

  y.ticks(5).forEach(t => {
    svg.append('line').attr('class','gridline').attr('x1', m.l).attr('x2', W - m.r).attr('y1', y(t)).attr('y2', y(t));
    svg.append('text').attr('class','tick-txt').attr('x', m.l - 8).attr('y', y(t)).attr('text-anchor','end').attr('dominant-baseline','middle').text(t + 'M');
  });
  const step = rows.length > 8 ? 2 : 1;
  svg.append('g').selectAll('text').data(rows.filter((d,i)=> i % step === 0 || i === rows.length-1)).join('text')
    .attr('class','tick-txt').attr('x', d => x(d.t)).attr('y', H - m.b + 15).attr('text-anchor','middle').text(d => d.t);
  svg.append('line').attr('class','axis-base').attr('x1', m.l).attr('x2', W - m.r).attr('y1', y(0)).attr('y2', y(0));

  const line = d3.line().x(d => x(d.t)).y(d => d.v).curve(d3.curveMonotoneX);
  series.forEach(s => {
    const pts = rows.map(d => ({ t: d.t, v: y(s.get(d)) }));
    svg.append('path').attr('class','series-line').attr('stroke', s.color).attr('d', line(pts));
    const last = rows[rows.length - 1];
    svg.append('circle').attr('class','marker-ring').attr('cx', x(last.t)).attr('cy', y(s.get(last))).attr('r', 4.5).attr('fill', s.color);
    if (s.labelIt) svg.append('text').attr('class','end-label').attr('x', x(last.t) + 10).attr('y', y(s.get(last)) + 4).text(fmtM(s.get(last)));
  });

  const tt = document.getElementById('lineTT');
  const cross = svg.append('line').attr('class','crosshair').attr('y1', m.t).attr('y2', H - m.b).style('opacity', 0);
  const focusDots = svg.append('g');
  svg.append('rect').attr('x', m.l).attr('y', m.t).attr('width', W - m.r - m.l).attr('height', H - m.b - m.t)
    .attr('fill', 'transparent').style('cursor','crosshair')
    .on('mousemove', function (ev) {
      const [mx] = d3.pointer(ev, svg.node());
      let idx = 0, best = Infinity;
      rows.forEach((d, i) => { const dd = Math.abs(x(d.t) - mx); if (dd < best) { best = dd; idx = i; } });
      const d = rows[idx];
      cross.attr('x1', x(d.t)).attr('x2', x(d.t)).style('opacity', 1);
      focusDots.selectAll('*').remove();
      series.forEach(s => focusDots.append('circle').attr('class','marker-ring').attr('cx', x(d.t)).attr('cy', y(s.get(d))).attr('r', 4).attr('fill', s.color));
      tt.innerHTML = `<div class="tt-h">${d.t}</div>` + series.map(s =>
        `<div class="tt-row"><span class="lab"><span class="k" style="background:${s.color}"></span>${s.label}</span><span class="val">${fmtM(s.get(d))}</span></div>`).join('');
      const rect = svg.node().getBoundingClientRect();
      tt.style.left = (x(d.t) * rect.width / W) + 'px';
      tt.style.top  = (y(d.a + d.b) * rect.height / H) + 'px';
      tt.style.opacity = 1;
    })
    .on('mouseleave', () => { cross.style('opacity', 0); focusDots.selectAll('*').remove(); tt.style.opacity = 0; });

  buildLegend(document.getElementById('lineLegend'), [
    { label: 'Total', c: css('--total'), dot: true },
    { label: L.aShort, c: css('--ma'), dot: true },
    { label: L.bShort, c: css('--ffs'), dot: true },
  ]);
}

function renderBar() {
  const rows = DATA[dash][range], L = DATA[dash].labels;
  const svg = d3.select('#barChart'); svg.selectAll('*').remove();
  const W = 560, H = 270, m = { t: 12, r: 16, b: 30, l: 40 };
  const y = d3.scaleLinear().domain([0, 100]).range([H - m.b, m.t]);
  const x = d3.scaleBand().domain(rows.map(d => d.t)).range([m.l, W - m.r]).padding(0.28);
  const bw = Math.min(24, x.bandwidth());
  const bx = d => x(d.t) + (x.bandwidth() - bw) / 2;

  y.ticks(5).forEach(t => {
    svg.append('line').attr('class','gridline').attr('x1', m.l).attr('x2', W - m.r).attr('y1', y(t)).attr('y2', y(t));
    svg.append('text').attr('class','tick-txt').attr('x', m.l - 8).attr('y', y(t)).attr('text-anchor','end').attr('dominant-baseline','middle').text(t + '%');
  });
  const step = rows.length > 8 ? 2 : 1;
  svg.append('g').selectAll('text').data(rows.filter((d,i)=> i % step === 0 || i === rows.length-1)).join('text')
    .attr('class','tick-txt').attr('x', d => bx(d) + bw/2).attr('y', H - m.b + 15).attr('text-anchor','middle').text(d => d.t);

  const GAP = 2, tt = document.getElementById('barTT'), g = svg.append('g');
  rows.forEach(d => {
    const total = d.a + d.b, pa = d.a / total * 100, pb = d.b / total * 100;
    const yB0 = y(0), yBtop = y(pb), yAtop = y(100);
    const col = g.append('g').style('cursor','pointer');
    col.append('rect').attr('x', bx(d)).attr('width', bw).attr('y', yBtop).attr('height', Math.max(0, yB0 - yBtop)).attr('fill', css('--ffs'));
    const aH = Math.max(0, (yBtop - GAP) - yAtop);
    col.append('rect').attr('x', bx(d)).attr('width', bw).attr('y', yAtop).attr('height', aH).attr('fill', css('--ma')).attr('rx', 4).attr('ry', 4);
    col.append('rect').attr('x', bx(d)).attr('width', bw).attr('y', yAtop + Math.min(4, aH)).attr('height', Math.max(0, aH - 4)).attr('fill', css('--ma'));
    col.on('mousemove', function () {
        tt.innerHTML = `<div class="tt-h">${d.t}</div>`
          + `<div class="tt-row"><span class="lab"><span class="k" style="background:${css('--ma')}"></span>${L.aShort}</span><span class="val">${Math.round(pa)}%</span></div>`
          + `<div class="tt-row"><span class="lab"><span class="k" style="background:${css('--ffs')}"></span>${L.bShort}</span><span class="val">${Math.round(pb)}%</span></div>`;
        const rect = svg.node().getBoundingClientRect();
        tt.style.left = ((bx(d) + bw/2) * rect.width / W) + 'px';
        tt.style.top  = (y(100) * rect.height / H + 6) + 'px';
        tt.style.opacity = 1;
      })
      .on('mouseleave', () => { tt.style.opacity = 0; });
  });

  buildLegend(document.getElementById('barLegend'), [ { label: L.aShort, c: css('--ma') }, { label: L.bShort, c: css('--ffs') } ]);
}

let stateFeatures = null;
async function initMap() {
  const fig = document.getElementById('mapFigure');
  try {
    const us = await d3.json('https://cdn.jsdelivr.net/npm/us-atlas@3/states-10m.json');
    stateFeatures = topojson.feature(us, us.objects.states).features;
    fig.innerHTML = '';
    const W = 975, H = 610;
    const projection = d3.geoAlbersUsa().scale(1280).translate([W/2, H/2]);
    const geoPath = d3.geoPath(projection);
    const svg = d3.select(fig).append('svg').attr('viewBox', `0 0 ${W} ${H}`).attr('role','img').attr('aria-label','US map of program penetration');
    svg.append('g').attr('id','statesG').selectAll('path').data(stateFeatures).join('path')
      .attr('class','state').attr('d', geoPath)
      .on('mousemove', (ev, f) => onStateHover(ev, f))
      .on('mouseleave', () => { if (!selectedState) resetFocus(); })
      .on('click', (ev, f) => { const nm = f.properties.name; focusState(STATES[nm] ? nm : ''); });
    const tt = document.createElement('div'); tt.className = 'tt'; tt.id = 'mapTT'; fig.appendChild(tt);
    paintMap();
  } catch (e) {
    fig.innerHTML = '<div class="map-error">Map could not be loaded (needs a connection to us-atlas). The rest of the dashboard works offline.</div>';
  }
}
function metricFor(name) {
  const s = STATES[name]; if (!s) return null;
  let ma = s[0]; if (dash === 'drug') ma = Math.min(85, Math.round(ma * 1.12));
  return { ma, ffs: 100 - ma, total: s[1] };
}
function paintMap() {
  if (stateFeatures) {
    d3.select('#statesG').selectAll('path')
      .attr('fill', f => { const m = metricFor(f.properties.name); return m ? rampColor(m.ma) : NO_DATA; })
      .classed('is-selected', f => f.properties.name === selectedState);
  }
  const r = MAP_RAMP[dash];
  document.getElementById('mapLegend').innerHTML =
    r.colors.map((c,i) => `<span class="item"><span class="chip" style="background:${c}"></span>${r.labels[i]}</span>`).join('')
    + `<span class="item"><span class="chip" style="background:${NO_DATA}"></span>No data</span>`;
  document.getElementById('map-title').textContent = DATA[dash].labels.mapTitle;
  document.getElementById('mapSub').textContent = DATA[dash].labels.mapSub;
}
function onStateHover(ev, f) {
  const name = f.properties.name, m = metricFor(name), tt = document.getElementById('mapTT');
  if (!m || !tt) return;
  updateFocus(name, m);
  const L = DATA[dash].labels;
  tt.innerHTML = `<div class="tt-h">${name}</div>`
    + `<div class="tt-row"><span class="lab"><span class="k" style="background:${css('--ma')}"></span>${L.aShort}</span><span class="val">${m.ma}%</span></div>`
    + `<div class="tt-row"><span class="lab"><span class="k" style="background:${css('--ffs')}"></span>${L.bShort}</span><span class="val">${m.ffs}%</span></div>`
    + `<div class="tt-row"><span class="lab">Total</span><span class="val">${fmtM(m.total)}</span></div>`;
  const box = document.getElementById('mapFigure').getBoundingClientRect();
  tt.style.left = (ev.clientX - box.left) + 'px';
  tt.style.top  = (ev.clientY - box.top) + 'px';
  tt.style.opacity = 1;
  clearTimeout(tt._h); tt._h = setTimeout(() => tt.style.opacity = 0, 1200);
}
function updateFocus(name, m) {
  const L = DATA[dash].labels;
  document.getElementById('focusLine').innerHTML =
    `<b>${name}</b><span class="sep">·</span>${L.aShort} ${m.ma}%<span class="sep">·</span>${L.bShort} ${m.ffs}%<span class="sep">·</span>${fmtM(m.total)} total`;
}
function resetFocus() {
  const s = DATA[dash].snapshot, L = DATA[dash].labels;
  document.getElementById('focusLine').innerHTML =
    `<b>United States</b><span class="sep">·</span>${L.aShort} ${pct(s.a,s.total)}%<span class="sep">·</span>${L.bShort} ${pct(s.b,s.total)}%<span class="sep">·</span>${fmtM(s.total)} total`;
}
function focusState(name) {
  selectedState = name; paintMap();
  if (name && metricFor(name)) updateFocus(name, metricFor(name)); else resetFocus();
}
function renderGridTables() {
  const L = DATA[dash].labels;
  const pctCells = r => `<td>${r.bPct}%</td><td>${r.aPct}%</td>`;

  document.querySelector('#stateTable thead').innerHTML =
    `<tr><th>State</th><th>Total</th><th>${L.bShort}</th><th>${L.aShort}</th><th>${L.bShort} %</th><th>${L.aShort} %</th></tr>`;
  const areas = Object.entries(STATES).concat(Object.entries(TERRITORIES)).sort((x, y) => x[0].localeCompare(y[0]));
  document.querySelector('#stateTable tbody').innerHTML = areas.map(([n, arr]) => {
    const r = areaRow(n, arr);
    return `<tr><td title="${n}">${ABBR[n] || n}</td>${numCell(r.total)}${numCell(r.b)}${numCell(r.a)}${pctCells(r)}</tr>`;
  }).join('');

  document.querySelector('#yearlyTable thead').innerHTML = `<tr><th>Year</th><th>Total</th><th>${L.bShort}</th><th>${L.aShort}</th><th>${L.bShort} %</th><th>${L.aShort} %</th></tr>`;
  document.querySelector('#yearlyTable tbody').innerHTML = DATA[dash].yearly.map(row => {
    const r = natRow(row, 'Y' + row.t);
    return `<tr><td>${row.t}</td>${numCell(r.total)}${numCell(r.b)}${numCell(r.a)}${pctCells(r)}</tr>`;
  }).join('');

  document.querySelector('#monthlyTable thead').innerHTML = `<tr><th>Year</th><th>Month</th><th>Total</th><th>${L.bShort}</th><th>${L.aShort}</th><th>${L.bShort} %</th><th>${L.aShort} %</th></tr>`;
  document.querySelector('#monthlyTable tbody').innerHTML = DATA[dash].monthly.map(row => {
    const yr = ['Jan', 'Feb', 'Mar'].includes(row.t) ? 2026 : 2025;
    const r = natRow(row, 'M' + row.t);
    return `<tr><td>${yr}</td><td>${row.t}</td>${numCell(r.total)}${numCell(r.b)}${numCell(r.a)}${pctCells(r)}</tr>`;
  }).join('');
}

function setDashboard(which) {
  dash = which;
  document.getElementById('tab-hospital').setAttribute('aria-pressed', which === 'hospital');
  document.getElementById('tab-drug').setAttribute('aria-pressed', which === 'drug');
  document.getElementById('trendSub').textContent = 'National · ' + (which === 'hospital' ? 'Hospital / Medical' : 'Prescription Drug');
  renderAll();
}
function setRange(r) {
  range = r;
  document.getElementById('range-yearly').setAttribute('aria-selected', r === 'yearly');
  document.getElementById('range-monthly').setAttribute('aria-selected', r === 'monthly');
  renderLine(); renderBar();
}
function setView(v) {
  view = v;
  const grid = v === 'grid';
  document.getElementById('view-map').setAttribute('aria-pressed', !grid);
  document.getElementById('view-grid').setAttribute('aria-pressed', grid);
  document.getElementById('mapView').hidden = grid;
  document.getElementById('gridStateView').hidden = !grid;
  document.getElementById('chartsView').hidden = grid;
  document.getElementById('tablesView').hidden = !grid;
  document.getElementById('rangeTabs').hidden = grid;
  document.getElementById('dashGrid').classList.toggle('is-grid', grid);
  applyGridTitles();
  if (grid) renderGridTables();
}
function applyGridTitles() {
  const grid = view === 'grid';
  document.getElementById('trend-title').textContent = grid ? 'Enrollment — data tables' : 'Enrollment trends over time';
  if (grid) {
    document.getElementById('map-title').textContent = 'All areas — enrollment by state';
    document.getElementById('mapSub').textContent = 'States and territories · counts and share of total';
  } else {
    paintMap();
  }
}
function renderAll() {
  renderHero(); renderLine(); renderBar();
  paintMap();
  if (selectedState) focusState(selectedState); else resetFocus();
  applyGridTitles();
  if (view === 'grid') renderGridTables();
}

renderAll();
initMap();
</script>
