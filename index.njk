    table.data { width: 100%; border-collapse: collapse; font-size: .81rem; }
    table.data th, table.data td { padding: 7px 11px; text-align: right; border-bottom: 1px solid var(--border); font-variant-numeric: tabular-nums; white-space: nowrap; }
    table.data th:first-child, table.data td:first-child { text-align: left; }
    table.data.two-label th:nth-child(2), table.data.two-label td:nth-child(2) { text-align: left; }
    table.data thead th { position: sticky; top: 0; background: var(--surface-2); color: var(--ink-2); font-weight: 700; font-size: .68rem; text-transform: uppercase; letter-spacing: .03em; box-shadow: inset 0 -1px 0 var(--border); }
    table.data tbody tr:last-child td { border-bottom: 0; }
    table.data tbody tr:hover td { background: var(--surface-2); }

    .trend-card { padding: 14px 16px; display: flex; flex-direction: column; }
    .trend-head { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 2px; }
    #chartsView { flex: 1; display: flex; flex-direction: column; justify-content: space-evenly; }
    .tabs { display: inline-flex; gap: 4px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 10px; padding: 3px; }
    .tabs button { appearance: none; border: 0; background: transparent; font: inherit; font-weight: 600; font-size: .8rem; color: var(--ink-2); padding: 6px 12px; border-radius: 8px; cursor: pointer; }
    .tabs button[aria-selected="true"] { background: var(--surface); color: var(--ink); box-shadow: 0 1px 2px rgba(16,16,24,.12); }
    .chart-block { margin-top: 14px; }
    .chart-block__head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 4px 14px; margin-bottom: 4px; }
    .chart-block h4 { font-size: .82rem; font-weight: 700; margin: 0; }
    .chart-block h4 span { color: var(--ink-2); font-weight: 500; font-size: .74rem; }
    .chart-svg { width: 100%; height: auto; display: block; overflow: visible; }

    .legend { display: flex; flex-wrap: wrap; gap: 6px 14px; }
    .legend .item { display: flex; align-items: center; gap: 7px; font-size: .77rem; color: var(--ink-2); font-weight: 600; }
    .legend .key { width: 17px; height: 3px; border-radius: 2px; }
    .legend .key.dot { width: 11px; height: 11px; border-radius: 50%; }

    .gridline { stroke: var(--grid); stroke-width: 1; }
    .axis-base { stroke: var(--baseline); stroke-width: 1; }
    .tick-txt { fill: var(--muted); font-size: 11px; font-variant-numeric: tabular-nums; }
    .end-label { fill: var(--ink); font-size: 12px; font-weight: 700; }
    .series-line { fill: none; stroke-width: 2; stroke-linejoin: round; stroke-linecap: round; }
    .marker-ring { stroke: var(--surface); stroke-width: 2; }
    .crosshair { stroke: var(--baseline); stroke-width: 1; stroke-dasharray: 3 3; }

    .tt { position: absolute; pointer-events: none; z-index: 5; opacity: 0; transform: translate(-50%, -120%);
      background: var(--surface); color: var(--ink); border: 1px solid var(--border);
